{
  "name": "ventanilla-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend de Ventanilla — API multi-tenant, auth, sincronización offline-first e integraciones (Wompi, WhatsApp, DIAN).",
  "author": "Dr. Mauricio Rodríguez Herrera",
  "license": "UNLICENSED",
  "copyright": "© Dr. Mauricio Rodríguez Herrera. Todos los derechos reservados.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "seed": "tsx src/seed.ts",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
