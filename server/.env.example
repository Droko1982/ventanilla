# Copia este archivo a .env y completa los valores.

# Base de datos PostgreSQL (en producción usa tu DB administrada: Neon, Supabase, Railway…)
DATABASE_URL="postgresql://ventanilla:ventanilla@localhost:5433/ventanilla?schema=public"

# Secreto para firmar los tokens (cambia esto por algo largo y aleatorio)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# Puerto del API
PORT=4000

# Orígenes permitidos (CORS). La app del demo y tu dominio.
CORS_ORIGIN="http://localhost:5173,https://droko1982.github.io"

# Super-Admin de la plataforma (para entrar a la consola)
SUPERADMIN_EMAIL="admin@ventanilla.co"
SUPERADMIN_PASSWORD="cambia-esta-clave"

# --- Integraciones (opcionales: si están vacías, el API responde en modo simulado) ---
# Pasarela de pago Wompi (https://comercios.wompi.co)
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_EVENTS_SECRET=""

# WhatsApp Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# Proveedor DIAN autorizado (Alegra / Factus). Cada tenant puede tener el suyo en su config.
DIAN_PROVIDER=""
DIAN_API_KEY=""
